# === PostgreSQL ===
PG_HOST=localhost
PG_PORT=5432
PG_DB=wpt
PG_USERNAME=wpt
PG_PASSWORD=wpt_dev_password

# === Backend ===
PORT=3000
HOST=0.0.0.0

# === UDP Ports ===
UDP_PORT_DATA=9090
UDP_PORT_ALARMS=9091
UDP_PORT_USERS=9092
UDP_PORT_ACK=9093
UDP_ADDRESS=0.0.0.0

# === Auth ===
SESSION_SECRET=change-me-to-a-random-32-char-string!!
ADMIN_PASSWORD=changeme
SESSION_COOKIE_SECURE=false
TRUST_PROXY=false

# === CORS ===
CORS_ORIGIN=http://localhost:3001

# === Frontend (build-time) ===
NEXT_PUBLIC_API_URL=http://localhost:3000

# === MQTT Gateway ===
# WARNING (production / real-PLC deployments only):
# When the backend runs with `network_mode: host` (the production setup on the
# OnLogic box, see docker-compose.prod.yml), Docker DNS does NOT resolve the
# `mosquitto` service name — the backend container is on the host network, not
# the compose bridge. You MUST override MQTT_HOST=127.0.0.1 below (see PRODUCTION
# OVERRIDES block) or the backend will silently log "Failed to connect to MQTT
# broker — continuing without MQTT" and the entire MQTT pipeline goes dark.
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=wpt-backend
MQTT_PASSWORD=wpt_mqtt_dev_password
MQTT_ENABLED=true
MQTT_SITE_ID=site-01
MQTT_MACHINE_ID=wpt40-001

# === Simulator (dev only, not needed in production) ===
SIM_HOST=localhost

# -------------------------------------------------------
# PRODUCTION OVERRIDES (set these on the OnLogic box):
# -------------------------------------------------------
# PG_HOST=127.0.0.1          (required with network_mode: host)
# MQTT_HOST=127.0.0.1        (REQUIRED with network_mode: host — see WARNING above
#                             in the MQTT Gateway section. Skipping this override
#                             silently disables MQTT publish/subscribe.)
# PG_PASSWORD=<strong-random>
# SESSION_SECRET=<random-32-chars>
# ADMIN_PASSWORD=<initial-admin>
# SESSION_COOKIE_SECURE=true
# TRUST_PROXY=true
# CORS_ORIGIN=https://wpt.local
# NEXT_PUBLIC_API_URL=https://wpt.local/api

# -------------------------------------------------------
# MQTT PASSWORD ROTATION (dynamic-security split-brain warning):
# -------------------------------------------------------
# MQTT_PASSWORD above is what the backend USES to log in as the wpt-backend client.
# The matching password HASH is stored separately, baked into:
#   wpt-iot/mosquitto/config/dynamic-security.json
# Mosquitto validates against that hash file, NOT against this env var.
#
# If you change MQTT_PASSWORD here without regenerating the hash, the broker will
# silently reject the backend and the entire MQTT pipeline goes dark. There is no
# loud failure in the backend logs by default — you have to tail mosquitto to see it.
#
# To rotate the password correctly, run (from inside the mosquitto container):
#   mosquitto_ctrl -u <admin-user> -P <admin-pass> dynsec setClientPassword wpt-backend <new-password>
# Then update MQTT_PASSWORD in this .env to match, and restart the backend.
#
# DO NOT hand-edit dynamic-security.json — the hash is PBKDF2-derived and will not
# match a plain-text replacement.
