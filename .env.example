# === PostgreSQL ===
PG_HOST=localhost
PG_PORT=5432
PG_DB=wpt
PG_USERNAME=wpt
PG_PASSWORD=wpt_dev_password

# === Backend ===
PORT=3000
HOST=0.0.0.0

# === UDP Ports ===
UDP_PORT_DATA=9090
UDP_PORT_ALARMS=9091
UDP_PORT_USERS=9092
UDP_PORT_ACK=9093
UDP_ADDRESS=0.0.0.0

# === Auth ===
SESSION_SECRET=change-me-to-a-random-32-char-string!!
ADMIN_PASSWORD=changeme
# Secure cookie defaults to true. Override to false ONLY for local HTTP dev.
SESSION_COOKIE_SECURE=true
TRUST_PROXY=true

# === Secrets-at-rest encryption ===
# 32 random bytes, base64-encoded. Used by secretCipher.ts (AES-256-GCM) to
# encrypt the MQTT broker password stored in mqtt_config.password at rest.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED before setting any MQTT password via the admin UI. LOSING THIS KEY
# MEANS LOSING THE ABILITY TO DECRYPT STORED SECRETS — back it up alongside
# the DB dump. Never commit the real value; the example below is a placeholder.
SECRETS_ENCRYPTION_KEY=REPLACE_WITH_BASE64_OF_32_RANDOM_BYTES

# === CORS / API URL ===
# Phase 37.3: CORS is deliberately eliminated. The backend emits no
# Access-Control-Allow-* headers. Browser traffic reaches /api only through
# the same origin as the frontend (nginx in prod, Next.js dev rewrite in dev).
# There is no CORS_ORIGIN variable and no NEXT_PUBLIC_API_URL to set for
# typical deployments. Leave NEXT_PUBLIC_API_URL empty unless you are running
# the backend on a physically different origin than the frontend (rare).
NEXT_PUBLIC_API_URL=

# -------------------------------------------------------
# PRODUCTION OVERRIDES (set these on the Pilz IndustrialPI 4 / customer edge box):
# -------------------------------------------------------
# PG_HOST=127.0.0.1          (required with network_mode: host)
# MQTT_HOST=127.0.0.1        (REQUIRED with network_mode: host — see WARNING above
#                             in the MQTT Gateway section. Skipping this override
#                             silently disables MQTT publish/subscribe.)
# PG_PASSWORD=<strong-random>
# SESSION_SECRET=<random-32-chars>
# ADMIN_PASSWORD=<initial-admin>
# SESSION_COOKIE_SECURE=true   (default in Phase 37.3)
# TRUST_PROXY=true             (default in Phase 37.3 — nginx sets X-Forwarded-*)
# NEXT_PUBLIC_API_URL=         (leave empty — same-origin via nginx)
# App URL=https://wpt.local    (or https://wpt-<serial>.local / cloud subdomain)
# CA download=https://wpt.local/setup/wpt-local-ca.crt

# -------------------------------------------------------
# MQTT PASSWORD ROTATION (dynamic-security split-brain warning):
# -------------------------------------------------------
# MQTT_PASSWORD above is what the backend USES to log in as the wpt-backend client.
# The matching password HASH is stored separately, baked into:
#   wpt-iot/mosquitto/config/dynamic-security.json
# Mosquitto validates against that hash file, NOT against this env var.
#
# If you change MQTT_PASSWORD here without regenerating the hash, the broker will
# silently reject the backend and the entire MQTT pipeline goes dark. There is no
# loud failure in the backend logs by default — you have to tail mosquitto to see it.
#
# To rotate the password correctly, run (from inside the mosquitto container):
#   mosquitto_ctrl -u <admin-user> -P <admin-pass> dynsec setClientPassword wpt-backend <new-password>
# Then update MQTT_PASSWORD in this .env to match, and restart the backend.
#
# DO NOT hand-edit dynamic-security.json — the hash is PBKDF2-derived and will not
# match a plain-text replacement.

# -------------------------------------------------------
# PILZ INDUSTRIALPI 4 (ARM64, 8 GB RAM, 32 GB eMMC) OVERRIDES
# -------------------------------------------------------
# Uncomment on the Pilz edge device. Defaults in docker-compose.yml are
# bench/dev-safe (small). Rationale and full disk/memory budget live in
# scripts/RUNBOOK.md under "Pilz IndustrialPI 4 (ARM64) Deployment".
# PG_SHARED_BUFFERS=2GB
# PG_WORK_MEM=16MB
# PG_EFFECTIVE_CACHE_SIZE=5GB
# PG_MAINTENANCE_WORK_MEM=512MB
# PG_SYNCHRONOUS_COMMIT=off        # eMMC wear mitigation; accepts up to ~1s data loss on power-cut
