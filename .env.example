# === PostgreSQL ===
PG_HOST=localhost
PG_PORT=5432
PG_DB=wpt
PG_USERNAME=wpt
PG_PASSWORD=wpt_dev_password

# === Backend ===
PORT=3000
HOST=0.0.0.0

# === UDP Ports ===
UDP_PORT_DATA=9090
UDP_PORT_ALARMS=9091
UDP_PORT_USERS=9092
UDP_PORT_ACK=9093
UDP_ADDRESS=0.0.0.0

# === Auth ===
SESSION_SECRET=change-me-to-a-random-32-char-string!!
ADMIN_PASSWORD=changeme

# === CORS ===
CORS_ORIGIN=http://localhost:3001

# === Frontend (build-time) ===
NEXT_PUBLIC_API_URL=http://localhost:3000

# === Simulator (dev only, not needed in production) ===
SIM_HOST=localhost

# -------------------------------------------------------
# PRODUCTION OVERRIDES (set these on the OnLogic box):
# -------------------------------------------------------
# PG_HOST=127.0.0.1          (required with network_mode: host)
# PG_PASSWORD=<strong-random>
# SESSION_SECRET=<random-32-chars>
# ADMIN_PASSWORD=<initial-admin>
# CORS_ORIGIN=http://wpt.local:3001
# NEXT_PUBLIC_API_URL=http://wpt.local:3000
